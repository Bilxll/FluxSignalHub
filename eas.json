{
  "cli": {
    "version": ">= 7.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "receiver-preview": {
      "distribution": "internal",
      "env": { "APP_VARIANT": "receiver" },
      "android": {
        "buildType": "apk"
      }
    },
    "admin-preview": {
      "distribution": "internal",
      "env": { "APP_VARIANT": "admin" },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
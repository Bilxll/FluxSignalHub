rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone (receiver app) can READ signals, challenges, compounding rows
    // Only authenticated admins (signed in via the Admin app) can WRITE
    match /signals/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /challenges/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /compoundingRows/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Any device can register/update its own push token (needed by receiver app)
    // but tokens cannot be read back by clients (admin app reads them via the
    // notifications helper which is allowed because it's authenticated)
    match /pushTokens/{token} {
      allow create, update: if true;
      allow read: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
